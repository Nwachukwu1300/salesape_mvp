generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  password             String
  name                 String
  refreshToken         String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  businesses           Business[]
  conversationSessions ConversationSession[]
  teamMemberships      TeamMember[]
  approvalsGiven       ApprovalHistory[]
}

model Business {
  id                     String                  @id @default(cuid())
  userId                 String
  name                   String
  url                    String
  description            String?
  logo                   String?
  publishedUrl           String?
  analysis               Json?
  generatedConfig        Json?
  isPublished            Boolean                 @default(false)
  publishedAt            DateTime?
  slug                   String?                 @unique
  googleCalendarTokens   String?
  outlookCalendarTokens  String?
  apiKeysEncrypted       String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  address                String?
  hours                  Json?
  phone                  String?
  views                  Int                     @default(0)
  abTests                ABTest[]
  analytics              Analytics[]
  availableSlots         AvailableSlot[]
  bookings               Booking[]
  user                   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  calendarBookings       CalendarBooking[]
  emailSequences         EmailSequence[]
  leads                  Lead[]
  payments               Payment[]
  subscription           Subscription?
  team                   Team?
  testimonials           Testimonial[]
  // New relationships
  websiteVersions        WebsiteVersion[]
  websiteAssets          WebsiteAsset[]
  contentInputs          ContentInput[]
  repurposedContent      RepurposedContent[]
  platformDistributions  PlatformDistribution[]
  analyticsSnapshots     AnalyticsSnapshot[]
  connectedAccounts      ConnectedAccount[]
  publishingControl      PublishingControl?
  growthModeSettings     GrowthModeSettings?
  bookingConfig          BookingConfig?
  scheduledPosts         ScheduledPost[]
  approvalHistory        ApprovalHistory[]
}

model Lead {
  id         String   @id @default(cuid())
  businessId String
  name       String
  email      String
  company    String?
  message    String?
  status     String   @default("new")
  source     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Booking {
  id         String   @id @default(cuid())
  businessId String
  name       String
  email      String
  date       String
  time       String
  status     String   @default("confirmed")
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, date, time])
}

model Testimonial {
  id          String   @id @default(cuid())
  businessId  String
  clientName  String
  clientTitle String?
  content     String
  rating      Int?
  imageUrl    String?
  isPublished Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model AvailableSlot {
  id         String   @id @default(cuid())
  businessId String
  dayOfWeek  Int
  startTime  String
  endTime    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model EmailSequence {
  id           String   @id @default(cuid())
  businessId   String
  name         String
  subject      String
  body         String
  delayMinutes Int      @default(0)
  triggerEvent String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Analytics {
  id         String   @id @default(cuid())
  businessId String
  eventType  String
  eventData  Json?
  source     String?
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Team {
  id               String            @id @default(cuid())
  businessId       String            @unique
  name             String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  leadRoutingRules LeadRoutingRule[]
  business         Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  members          TeamMember[]
}

model TeamMember {
  id        String    @id @default(cuid())
  teamId    String
  userId    String
  role      String    @default("member")
  email     String
  status    String    @default("invited")
  invitedAt DateTime  @default(now())
  joinedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  team      Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, email])
}

model LeadRoutingRule {
  id         String   @id @default(cuid())
  teamId     String
  assignTo   String
  service    String?
  leadSource String?
  priority   Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                   String   @id @default(cuid())
  businessId           String   @unique
  planId               String
  status               String   @default("active")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  business             Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String   @id @default(cuid())
  businessId      String
  stripePaymentId String?
  amount          Int
  currency        String   @default("usd")
  status          String   @default("pending")
  description     String?
  invoiceUrl      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model ABTest {
  id         String    @id @default(cuid())
  businessId String
  name       String
  variantA   Json
  variantB   Json
  status     String    @default("running")
  winner     String?
  confidence Int       @default(0)
  metricsA   Json?
  metricsB   Json?
  startDate  DateTime  @default(now())
  endDate    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model SeoAudit {
  id              String   @id @default(cuid())
  userId          String?
  businessId      String?
  url             String
  performance     Int
  seo             Int
  accessibility   Int
  bestPractices   Int
  issues          Json?
  recommendations Json?
  raw             Json?
  createdAt       DateTime @default(now())
}

model AuditUsage {
  id        String   @id @default(cuid())
  userId    String
  year      Int
  month     Int
  count     Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([userId, year, month])
}

model CalendarBooking {
  id         String   @id @default(cuid())
  businessId String
  leadId     String?
  provider   String
  startTime  DateTime
  endTime    DateTime
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model PublicSeoAudit {
  id              String   @id @default(cuid())
  url             String
  email           String
  ipAddress       String
  performance     Int
  seo             Int
  mobile          Int
  overallScore    Int
  issues          Json?
  recommendations Json?
  raw             Json?
  createdAt       DateTime @default(now())

  @@index([ipAddress, createdAt])
  @@index([email, createdAt])
}

model ConversationSession {
  id        String   @id @default(cuid())
  userId    String
  messages  Json
  extracted Json?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model VisitLog {
  ipDate    String   @id
  clientIp  String
  visitDate String
  createdAt DateTime @default(now())

  @@index([clientIp, visitDate])
}

// ===== NEW MODELS FOR WORKFLOW =====

model WebsiteVersion {
  id           String   @id @default(cuid())
  businessId   String
  versionNumber Int
  config       Json
  template     String
  status       String   @default("draft") // draft, published, archived
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, versionNumber])
  @@index([businessId, status])
  @@index([businessId, createdAt])
}

model WebsiteAsset {
  id         String   @id @default(cuid())
  businessId String
  type       String   // logo, image, icon, etc
  url        String
  source     String   // extracted, generated, uploaded
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, type])
  @@index([businessId, source])
}

model ContentInput {
  id                String               @id @default(cuid())
  businessId        String
  type              String               // text, video, audio, blog_url
  title             String?
  content           String?
  url               String?
  storagePath       String?
  status            String               @default("processing") // processing, ready, failed
  metadata          Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  business          Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  repurposedContent RepurposedContent[]

  @@index([businessId, status])
  @@index([businessId, type])
  @@index([businessId, createdAt])
}

model RepurposedContent {
  id                String                 @id @default(cuid())
  businessId        String
  contentInputId    String
  platform          String                 // instagram, tiktok, youtube, twitter, linkedin
  content           String
  caption           String?
  hashtags          Json?
  status            String                 @default("draft") // draft, approved, published
  publishedAt       DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  contentInput      ContentInput           @relation(fields: [contentInputId], references: [id], onDelete: Cascade)
  business          Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  distributions     PlatformDistribution[]
  scheduledPosts    ScheduledPost[]
  approvalHistory   ApprovalHistory[]

  @@index([businessId, platform])
  @@index([businessId, status])
  @@index([businessId, createdAt])
  @@index([contentInputId])
}

model PlatformDistribution {
  id                  String            @id @default(cuid())
  businessId          String
  repurposedContentId String
  platform            String
  externalId          String?
  url                 String?
  metrics             Json?             // views, likes, shares, comments, etc
  publishedAt         DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  repurposedContent   RepurposedContent @relation(fields: [repurposedContentId], references: [id], onDelete: Cascade)
  business            Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, platform])
  @@index([businessId, createdAt])
  @@index([repurposedContentId])
}

model AnalyticsSnapshot {
  id                    String   @id @default(cuid())
  businessId            String
  snapshotDate          DateTime
  engagementRate        Float    @default(0)
  completionRate        Float    @default(0)
  viewVelocity          Float    @default(0)
  ctr                   Float    @default(0)
  conversionSignals     Int      @default(0)
  aiCitationFrequency   Float    @default(0)
  seoImpactTrend        String   @default("neutral") // positive, neutral, negative
  aeoImpactTrend        String   @default("neutral") // positive, neutral, negative
  metadata              Json?
  createdAt             DateTime @default(now())
  business              Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, snapshotDate])
  @@index([businessId, snapshotDate])
  @@index([businessId, createdAt])
}

model ConnectedAccount {
  id           String   @id @default(cuid())
  businessId   String
  platform     String   // instagram, tiktok, youtube, twitter, linkedin, facebook
  accountId    String
  accountName  String?
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, platform, accountId])
  @@index([businessId, platform])
  @@index([businessId, isActive])
}

model PublishingControl {
  id                String   @id @default(cuid())
  businessId        String   @unique
  requiresApproval  Boolean  @default(false)
  autoPublish       Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  business          Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model GrowthModeSettings {
  id            String   @id @default(cuid())
  businessId    String   @unique
  mode          String   @default("BALANCED") // CONSERVATIVE, BALANCED, AGGRESSIVE
  outputLimit   Int      @default(5)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model BookingConfig {
  id                 String   @id @default(cuid())
  businessId         String   @unique
  isEnabled          Boolean  @default(true)
  timezone           String   @default("UTC")
  requiresApproval   Boolean  @default(false)
  notificationEmail  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  business           Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}
// Phase 4: Scheduling & Approval Models
model ScheduledPost {
  id                  String            @id @default(cuid())
  businessId          String
  repurposedContentId String
  scheduledFor        DateTime
  status              String            @default("pending") // pending, published, failed, cancelled
  error               String?
  publishedAt         DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  business            Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  repurposedContent   RepurposedContent @relation(fields: [repurposedContentId], references: [id], onDelete: Cascade)

  @@index([businessId, status])
  @@index([businessId, scheduledFor])
  @@index([repurposedContentId])
  @@index([status, scheduledFor])
}

model ApprovalHistory {
  id                  String            @id @default(cuid())
  businessId          String
  repurposedContentId String
  action              String            // approved, rejected, published, submitted_for_approval
  approvedBy          String?           // userId or null for system actions
  comment             String?
  createdAt           DateTime          @default(now())
  business            Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  repurposedContent   RepurposedContent @relation(fields: [repurposedContentId], references: [id], onDelete: Cascade)
  approver            User?             @relation(fields: [approvedBy], references: [id], onDelete: SetNull)

  @@index([businessId, repurposedContentId])
  @@index([businessId, createdAt])
  @@index([repurposedContentId])
}
// New models for Settings and audit
model UserSettings {
  id            String   @id @default(cuid())
  userId        String   @unique
  memoryEnabled Boolean  @default(false)
  topK          Int      @default(5)
  ttlDays       Int      @default(30)
  twoFA         Boolean  @default(false)
  growthMode    String   @default("BALANCED")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  userId     String
  action     String
  details    Json?
  createdAt  DateTime @default(now())
}

model AccountDeletionRequest {
  id              String   @id @default(cuid())
  userId          String
  requestedBy     String
  status          String   @default("PENDING") // PENDING, CANCELLED, COMPLETED
  scheduledAt     DateTime?
  requestedAt     DateTime @default(now())
  reason          String?
}
